# ─── LLM provider routing ───────────────────────────────────────────────────
# Default: OpenAI direct.
# - To use Groq instead: comment out LLM_PROVIDER=openai (Groq auto-selects when GROQ_API_KEY is set).
# - To route via OpenRouter: set OPENAI_BASE_URL and use OpenRouter slugs ("openai/gpt-4o").
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-key-here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1   # uncomment to route via OpenRouter

# Groq (kept for teammates). When GROQ_API_KEY is set AND LLM_PROVIDER is NOT "openai",
# the agent pipeline auto-routes to Groq (llama-3.3-70b-versatile by default).
GROQ_API_KEY=your-groq-key-here

# Default model names. Use plain names ("gpt-4o") with OpenAI direct.
# When OPENAI_BASE_URL points to OpenRouter, switch to slugs ("openai/gpt-4o").
OPENAI_MODEL=gpt-4o
OPENAI_ZERO_SHOT_MODEL=gpt-4o
OPENAI_RAG_MODEL=gpt-4o-mini
OPENAI_EVAL_MODEL=gpt-4o-mini

# ─── Google Fonts (used by tools/font_lookup.py) ─────────────────────────────
GOOGLE_FONTS_KEY=your-google-fonts-key-here
GOOGLE_FONTS_API_KEY=your-google-fonts-key-here

# ─── Lever toggles (1=on, 0=off). All default ON. ───────────────────────────
# Font whitelist: archetype-specific canonical Google Fonts in tools/font_lookup.py
BRANDMIND_FONT_WHITELIST=1
# Tone-keyword injection: archetype canonical descriptors prepended in agent2.py
BRANDMIND_TONE_INJECTION=1
# Narrative: LLM-generated archetype_alignment field in agent2.py
BRANDMIND_NARRATIVE=1
